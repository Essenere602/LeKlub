# Project
APP_ENV=dev
APP_SECRET=change_me

# Backend
BACKEND_PORT=8080
CORS_ALLOW_ORIGIN=http://localhost:19006

# Database
MYSQL_PORT=3307
MYSQL_DATABASE=leklub
MYSQL_USER=leklub
MYSQL_PASSWORD=leklub_password
MYSQL_ROOT_PASSWORD=root_password
DATABASE_URL=mysql://leklub:leklub_password@mysql:3306/leklub?serverVersion=8.0&charset=utf8mb4

# JWT
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me

# Football API - football-data.org
FOOTBALL_DATA_API_BASE_URL=https://api.football-data.org
FOOTBALL_DATA_API_TOKEN=change_me
FOOTBALL_DATA_API_TIMEOUT=3.0

# WebSocket
WEBSOCKET_PORT=8081
WEBSOCKET_URL=ws://localhost:8081

# Mobile
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api
EXPO_PUBLIC_WEBSOCKET_URL=ws://localhost:8081
